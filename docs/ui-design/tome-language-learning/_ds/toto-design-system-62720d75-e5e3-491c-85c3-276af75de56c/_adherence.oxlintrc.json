      "--dur-ui",
      "--ease-anvil",
      "--ease-out",
      "--fg-invert",
      "--fg-on-dark",
      "--fg1",
      "--fg2",
      "--fg3",
      "--font-brand",
      "--font-system",
      "--font-ui",
      "--on-primary",
      "--press-scale",
